{
  "name": "typing-everywhere",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node --test tests/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include=src/**/*.js --test-coverage-lines=90 --test-coverage-functions=90 --test-coverage-branches=85 tests/*.test.js",
    "lint": "eslint .",
    "verify": "npm run lint && npm run test:coverage && npm run build && node --test tests/build.test.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "jsdom": "^26.1.0"
  }
}
